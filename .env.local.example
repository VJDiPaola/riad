# Vercel AI Gateway — used by the companion agent (Stream C)
AI_GATEWAY_API_KEY=

# Benefits-knowledge MCP server URL (Stream B). Default matches `pnpm mcp` script.
BENEFITS_MCP_URL=http://localhost:8787/mcp

# Port the MCP server listens on
BENEFITS_MCP_PORT=8787

# Demo timer for the durable scheduledCheckIn step (ms). 30s default.
COMPANION_CHECKIN_DELAY_MS=30000
